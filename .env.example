# ─────────────────────────────────────────────────────────────
#  DevPilot — Environment Variable Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Provider Selection ────────────────────────────────────────
# Options: anthropic | openai
DEVPILOT_PROVIDER=anthropic

# ── Model Selection ───────────────────────────────────────────
# Anthropic: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
# OpenAI:    gpt-4o, gpt-4o-mini
DEVPILOT_MODEL=claude-opus-4-5

# ── API Keys ─────────────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── OpenAI-Compatible Base URL (for Ollama or other local models)
# Example: http://localhost:11434/v1
DEVPILOT_BASE_URL=

# ── Agentic Loop ─────────────────────────────────────────────
# Maximum model iterations before the loop is aborted
DEVPILOT_MAX_ITERATIONS=50

# ── Safety ───────────────────────────────────────────────────
# Set to "true" to bypass confirmation prompts (for CI pipelines)
DEVPILOT_NO_CONFIRM=false

# ── A2A Server ───────────────────────────────────────────────
# Port the A2A HTTP server listens on
DEVPILOT_A2A_PORT=8000

# Optional bearer token to secure A2A endpoints
DEVPILOT_A2A_TOKEN=

# ── Sessions ─────────────────────────────────────────────────
# Directory where session JSON files are saved
DEVPILOT_SESSIONS_DIR=.devpilot_sessions
